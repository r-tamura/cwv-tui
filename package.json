{
  "name": "@r-tamura/cwv-tui",
  "version": "0.3.0",
  "description": "Terminal UI for browsing AWS CloudWatch Logs and Metrics (dashboards, alarms, Insights, Live Tail)",
  "type": "module",
  "bin": {
    "cwv-tui": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src",
    "tsup.config.ts",
    "tsconfig.json"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "prepare": "tsup",
    "dev": "tsx src/cli.tsx",
    "demo": "tsx src/cli.tsx --config ./examples/dashboards.yaml",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.1052.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1050.0",
    "asciichart": "^1.5.25",
    "ink": "^7.0.3",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "js-yaml": "^4.1.1",
    "react": "^19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.15",
    "aws-sdk-client-mock": "^4.1.0",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/r-tamura/cwv-tui"
  },
  "license": "MIT"
}
